{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Execute",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/auto-tmux-dev.js"
          }
        ],
        "description": "Auto-start dev servers in tmux with directory-based session names",
        "id": "pre:execute:auto-tmux-dev"
      },
      {
        "matcher": "Execute",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"pre:execute:commit-quality\" \"scripts/hooks/pre-bash-commit-quality.js\" \"strict\""
          }
        ],
        "description": "Pre-command quality reminder before destructive git actions",
        "id": "pre:execute:commit-quality"
      },
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"pre:edit:create:config-protection\" \"scripts/hooks/config-protection.js\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "description": "Block modifications to protected config files",
        "id": "pre:edit:create:config-protection"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"pre:mcp-health-check\" \"scripts/hooks/mcp-health-check.js\" \"standard,strict\""
          }
        ],
        "description": "Check MCP server health before MCP tool execution",
        "id": "pre:mcp-health-check"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/session-start-bootstrap.js"
          }
        ],
        "description": "Load previous context and detect package manager on session start",
        "id": "session:start"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"post:quality-gate\" \"scripts/hooks/quality-gate.js\" \"standard,strict\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Run quality gate checks after file edits",
        "id": "post:quality-gate"
      },
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"post:edit:design-quality-check\" \"scripts/hooks/design-quality-check.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "description": "Warn when frontend edits drift toward generic template UI",
        "id": "post:edit:design-quality-check"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"post:edit:console-warn\" \"scripts/hooks/post-edit-console-warn.js\" \"standard,strict\""
          }
        ],
        "description": "Warn about console.log statements after edits",
        "id": "post:edit:console-warn"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"stop:format-typecheck\" \"scripts/hooks/stop-format-typecheck.js\" \"standard,strict\"",
            "timeout": 300
          }
        ],
        "description": "Batch format and typecheck edited JS/TS files once per response",
        "id": "stop:format-typecheck"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"stop:check-console-log\" \"scripts/hooks/check-console-log.js\" \"standard,strict\""
          }
        ],
        "description": "Check for console.log in modified files after each response",
        "id": "stop:check-console-log"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"stop:session-end\" \"scripts/hooks/session-end.js\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Persist session state after each response",
        "id": "stop:session-end"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/scripts/hooks/run-with-flags.js \"session:end:marker\" \"scripts/hooks/session-end-marker.js\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Session end lifecycle marker",
        "id": "session:end:marker"
      }
    ]
  }
}
