{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"prompt:hookify\" \"scripts/hooks/hookify-runtime.js\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "description": "Apply user-defined Hookify prompt rules",
        "id": "prompt:hookify"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Execute",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/pre-execute-dispatch.js\"",
            "timeout": 10
          }
        ],
        "description": "Execute pre-checks: hookify rules, auto-tmux-dev, commit quality",
        "id": "pre:execute:dispatch"
      },
      {
        "matcher": "Edit|Create|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"pre:file:hookify\" \"scripts/hooks/hookify-runtime.js\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "description": "Apply user-defined Hookify file rules",
        "id": "pre:file:hookify"
      },
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"pre:edit:create:config-protection\" \"scripts/hooks/config-protection.js\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "description": "Block modifications to protected config files",
        "id": "pre:edit:create:config-protection"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"pre:mcp-health-check\" \"scripts/hooks/mcp-health-check.js\" \"standard,strict\""
          }
        ],
        "description": "Check MCP server health before MCP tool execution",
        "id": "pre:mcp-health-check"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/session-start-bootstrap.js\""
          }
        ],
        "description": "Load previous context and detect package manager on session start",
        "id": "session:start"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"post:quality-gate\" \"scripts/hooks/quality-gate.js\" \"standard,strict\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Run quality gate checks after file edits",
        "id": "post:quality-gate"
      },
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"post:edit:design-quality-check\" \"scripts/hooks/design-quality-check.js\" \"standard,strict\"",
            "timeout": 10
          }
        ],
        "description": "Warn when frontend edits drift toward generic template UI",
        "id": "post:edit:design-quality-check"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"post:edit:console-warn\" \"scripts/hooks/post-edit-console-warn.js\" \"standard,strict\""
          }
        ],
        "description": "Warn about console.log statements after edits",
        "id": "post:edit:console-warn"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"stop:dispatch\" \"scripts/hooks/stop-dispatch.js\" \"minimal,standard,strict\"",
            "timeout": 300
          }
        ],
        "description": "Run the plugin stop pipeline once per response",
        "id": "stop:dispatch"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"session:end:marker\" \"scripts/hooks/session-end-marker.js\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Session end lifecycle marker",
        "id": "session:end:marker"
      }
    ]
  }
}
