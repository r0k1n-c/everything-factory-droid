{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EFD Install Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "target": {
      "type": "string",
      "enum": [
        "factory-droid"
      ]
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(baseline|lang|framework|capability|agent|skill):[a-z0-9-]+$"
      }
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(baseline|lang|framework|capability|agent|skill):[a-z0-9-]+$"
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
